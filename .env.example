# Proveedor de modelo (obligatorio para runWithMap y el benchmark)
MAP_PROVIDER=anthropic            # anthropic | openai
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Embedder (para el retrieval)
MAP_EMBEDDER=local                # local | openai
# OPENAI_API_KEY=                 # requerido si MAP_EMBEDDER=openai

# Modelos OpenAI por tier (ajusta a tu cuenta)
# OPENAI_MODEL_CHEAP=gpt-4o-mini
# OPENAI_MODEL_MEDIUM=gpt-4o
# OPENAI_MODEL_STRONG=gpt-4o

# MCP: corpus en JSON [{id,namespace,text}] para poblar el retriever en memoria
# MAP_CORPUS=./chunks.json

# Producción con pgvector
# DATABASE_URL=postgresql://user:pass@host:5432/db
